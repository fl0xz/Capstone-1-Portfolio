# Foundry Labs — Environment Variables
# Copy to Vercel → Project → Settings → Environment Variables

# App URL (your Vercel deployment)
APP_URL=https://your-app.vercel.app

# Amazon UK SP-API (register once at Seller Central → Develop Apps)
AMAZON_APPLICATION_ID=amzn1.sellerapps.app.xxxxx
AMAZON_LWA_CLIENT_ID=amzn1.application-oa2-client.xxxxx
AMAZON_LWA_CLIENT_SECRET=your-client-secret
AMAZON_REDIRECT_URI=https://your-app.vercel.app/api/amazon/callback
AMAZON_DRAFT_APP=true

# Supabase (optional — for auth + token storage)
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
